{
  "name": "polydomain",
  "version": "0.4.1",
  "description": "Scaffold a command center for your AI coding agent: a thin router, per-domain capsules, persistent memory, and an optional Obsidian/notes knowledge base — the Capsule architecture.",
  "keywords": [
    "cli",
    "scaffolding",
    "ai-agents",
    "agentic-ai",
    "claude-code",
    "command-center",
    "developer-tools",
    "npx",
    "typescript",
    "memory",
    "obsidian",
    "knowledge-management"
  ],
  "homepage": "https://alejandrehl.github.io/polydomain/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alejandrehl/polydomain.git"
  },
  "bugs": {
    "url": "https://github.com/Alejandrehl/polydomain/issues"
  },
  "author": "Alejandro Hernández Lara",
  "license": "MIT",
  "type": "module",
  "bin": {
    "polydomain": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "smoke": "node test/smoke/run-smoke.mjs"
  },
  "packageManager": "pnpm@10.23.0",
  "dependencies": {
    "@clack/prompts": "^1.5.0",
    "cac": "^7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
